#!/bin/sh
# USB Keyboard udev wrapper
# Called by udev rules, logs output and invokes main script
#
# IMPORTANT: The main script MUST run in the background (& + disown)
# so that udev can finish processing the device. Otherwise the script
# blocks udev and prevents the keyboard from fully initializing.

LOG=/var/log/kbd-auto-layout.log
SCRIPT=/usr/local/bin/kbd-auto-layout

# Log the event
{
    echo ""
    date "+[%Y-%m-%d %H:%M:%S] udev event: $*"
    echo "SUBSYSTEM=$SUBSYSTEM ACTION=$ACTION KERNEL=$KERNEL"
} >> "$LOG"

# Run the main script in background to not block udev
if [ -x "$SCRIPT" ]; then
    "$SCRIPT" "$@" >> "$LOG" 2>&1 &
else
    echo "Error: $SCRIPT not found or not executable" >> "$LOG"
fi
